#include <stdio.h>
#include<stdlib.h>
int main()
{
    int num, temp, digit, sum=0, count=0, search;
    printf("Enter a Number : ");
    scanf("%d", &num);
    printf("Enter the digit to count : ");
    scanf("%d", &search);
    temp=num;
    if (temp==0)
    {
        sum=0;
        if (search==0)
        count=1;
    }
    else
    {
        while(temp>0)
        {
            digit=temp%10;
            sum+=digit;
            if(digit==search)
            count++;
            temp=temp/10;
        }
    }
    printf("Sum of digits = %d\n",sum);
    printf("digit %d appears %d times\n", search, count);
    return 0;
}
