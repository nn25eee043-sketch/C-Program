#include<stdio.h>
#include<stdlib.h>
int a[10][10], m, n, i ,j;
void readmat();
void printmat();
void colsum();
void rowsum();
void totalsum();
int main()
{
    printf("Enter the dimensions of the matrix \n");
    scanf("%d%d", &m, &n);
    readmat();
    printmat();
    colsum();
    rowsum();
    totalsum();
    return 0;
}
void readmat()
{
    printf("Enter the elements of the matrix:\n");
    for(i=0;i<m;i++)
    {
        for(j=0;j<n;j++)
        {
            scanf("%d", &a[i][j]);
        }
    }
}
void printmat()
{
    printf("The Matrix is:\n");
    for(i=0;i<m;i++)
        {
            for(j=0;j<n;j++)
            {
                printf("%d\t", a[i][j]);
            }
            printf("\n");
        }
}
void rowsum()
{
    int sum;
    for(i=0;i<m;i++)
    {
        sum=0;
        for(j=0;j<n;j++)
        {
            sum+=a[i][j];
        }
        printf("Sum of row %d = %d\n", i+1, sum);
    }
}
void colsum()
{
    int sum;
    for(j=0;j<n;j++)
    {
        sum=0;
        for(i=0;i<m;i++)
        {
            sum+=a[i][j];
        }
        printf("Sum of column %d = %d\n", j+1, sum);
    }
}
void totalsum()
{
    int sum=0;
    for(i=0;i<m;i++)
    {
        for(j=0;j<n;j++)
        {
            sum+=a[i][j];
        }
    }
    printf("Total sum of matrix = %d\n", sum);
}
