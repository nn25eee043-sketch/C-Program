#include <stdio.h>
#include <stdlib.h>

int main()
{
    int a[100],i,n,*p,sum=0;
    printf("Enter the Length of the array:\n");
    scanf("%d",&n);
    printf("Enter elements for array\n");
    for(i=0;i<n;i++)
    {
        scanf("%d",&a[i]);

    }
    p=a;
    for(i=0;i<n;i++)
    {
        sum=sum+*p;
        p=p+1;
    }
    printf("The sum is %d\n",sum);
    return 0;
}
