#include <stdio.h>
int main()
{
    int a[10][10],i ,j ,transpose[10][10], rows, cols, trace=0;
    printf("Enter number of rows and columns:\n");
    scanf("%d%d",&rows,&cols);
    printf("Enter the elements of the matrix:\n");
    for(i=0;i<rows;i++)
    {
        for(j=0;j<cols;j++)
        {
            scanf("%d",&a[i][j]);
        }
    }
    printf("Given Matrix:\n");
    for(i=0;i<rows;i++)
    {
        for(j=0;j<cols;j++)
        {
            printf("%d  ", a[i][j]);
        }
        printf("\n");
    }
    for(i=0;i<rows;i++)
    {
        for(j=0;j<cols;j++)
        {
            transpose [j][i]=a[i][j];
        }
    }
    printf("the transpose of the matrix:\n");
    for(i=0;i<cols;i++)
    {
        for(j=0;j<rows;j++)
        {
            printf("%d  ", transpose[i][j]);
        }
        printf("\n");
    }
    if(rows==cols)
{
    for(i=0;i<rows;i++)
    {
        trace+=a[i][i];
    }
    printf("Trace of the matrix=%d\n", trace);
}
else
{
    printf("Trace is not possible\n");
}
    return 0;
}
