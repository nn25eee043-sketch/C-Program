#include <stdio.h>
#include <string.h>

int main()
{
    int n, i, flag=1;
    char str1[100];
    printf("Enter the Word: ");
    scanf("%s", str1);
    n=strlen(str1);
    for (i=0; i<n/2; i++)
    {
        if (str1[i] != str1[n - i - 1])
        {
            flag = 0;
            break;
        }
    }
    if (flag)
        printf("The entered word is palindrome.\n", str1);
    else
        printf("The entered word is not palindrome.\n", str1);
    return 0;
}
