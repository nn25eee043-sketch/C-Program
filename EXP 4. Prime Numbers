#include <stdio.h>
int main()
{
    int n1, n2, i, j, flag, count = 0;
    printf("Enter the range of numbers to display prime numbers:\n");
    scanf("%d %d", &n1, &n2);
    printf("Prime numbers between %d and %d are:\n", n1, n2);
    for (i = n1; i <= n2; i++) {
        if (i < 2)
            continue;

        flag = 0;

        for (j = 2; j <= i / 2; j++) {
            if (i % j == 0) {
                flag = 1;
                break;
            }
        }

        if (flag == 0) {
            count++;
            printf("%d\t", i);
        }
    }

    if (count == 0)
        printf("No prime numbers are found");

    return 0;
}
