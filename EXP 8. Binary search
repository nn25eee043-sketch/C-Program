#include <stdio.h>
#include <stdlib.h>
int main()
{
    int a[10], n, i, low, high, mid, key, found = 0;
    printf("Enter length of the array:\n");
    scanf("%d", &n);
    printf("Enter sorted array elements:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }
    printf("Enter the key: ");
    scanf("%d", &key);
    low = 0;
    high = n - 1;
    while(low <= high)
    {
        mid=(low+high)/2;
        if(a[mid]==key)
        {
            found=1;
            break;
        }
        else if(a[mid]<key)
            low=mid+1;
        else
            high=mid-1;
    }
    if(found==1)
        printf("The key exists at position %d\n", mid + 1);
    else
        printf("Key does not exist\n");
        return 0;
}
